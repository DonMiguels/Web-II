# ============================================================
# WEB-II /env/.env.example
# Plantilla base sin secretos reales
# ============================================================

# --- APP / RUNTIME ---
# development | test | production
NODE_ENV=development
APP_NAME=web-ii

# --- SERVER ---
SERVER_PORT=3000
SERVER_HOST=localhost
SERVER_PROTOCOL=http
SERVER_LANGUAGE=es
SERVER_PUBLIC_URL=http://localhost:3000
SERVER_CORS_ALLOWED_ORIGINS=http://localhost:5173

# --- SESSION ---
SESSION_SECRET=tu_session_secret_local
SESSION_COOKIE_NAME=webii.sid
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_HTTP_ONLY=true
SESSION_COOKIE_MAX_AGE_MS=300000
SESSION_RESAVE=false
SESSION_SAVE_UNINITIALIZED=true

# --- AUTH / JWT ---
JWT_SECRET=tu_jwt_secret_local
JWT_EXPIRES_IN=5m

# --- DATABASE (APP) ---
DB_POSTGRES_HOST=127.0.0.1
DB_POSTGRES_PORT=5432
DB_POSTGRES_NAME=webii
DB_POSTGRES_USER=tu_usuario_local
DB_POSTGRES_PASSWORD=tu_password_local
DB_POSTGRES_SSL=false

# --- SERVICES (THIRD-PARTY) ---
SERVICE_RESEND_API_KEY=
SERVICE_MAIL_FROM=onboarding@resend.dev

# --- FRONTEND (VITE) ---
VITE_API_URL=http://localhost:3000/user
FRONTEND_PUBLIC_URL=http://localhost:5173

# --- DOCKER / INFRA ---
DOCKER_POSTGRES_USER=tu_usuario_local
DOCKER_POSTGRES_PASSWORD=tu_password_local
DOCKER_POSTGRES_DB=postgres
DOCKER_POSTGRES_MULTIPLE_DATABASES=webii
DOCKER_RESTORE_FROM_BACKUP=false
DOCKER_POSTGRES_BIND_PORT=5431
DOCKER_PGADMIN_PORT=5050
DOCKER_PGADMIN_DEFAULT_EMAIL=admin@local.dev
DOCKER_PGADMIN_DEFAULT_PASSWORD=cambia_este_password
DOCKER_BACKUP_ON_START=true
DOCKER_BACKUP_ON_STOP=true
DOCKER_BACKUP_KEEP_DAYS=7
DOCKER_BACKUP_SCHEDULE=@daily
DOCKER_BACKUP_HEALTHCHECK_PORT=8080

# --- COMPAT LEGACY (TRANSICION) ---
# Estas variables se mantienen para no romper el codigo existente.
PORT=3000
IP=localhost
PROTOCOL=http
LANGUAGE=es

DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=webii
DB_USER=tu_usuario_local
DB_PASSWORD=tu_password_local

SECRET=tu_session_secret_local
RESEND_API_KEY=
EMAIL=onboarding@resend.dev
FRONTEND_URL=http://localhost:5173

POSTGRES_USER=tu_usuario_local
POSTGRES_PASSWORD=tu_password_local
POSTGRES_DB=postgres
POSTGRES_MULTIPLE_DATABASES=webii
RESTORE_FROM_BACKUP=false
PGADMIN_DEFAULT_EMAIL=admin@local.dev
PGADMIN_DEFAULT_PASSWORD=cambia_este_password
